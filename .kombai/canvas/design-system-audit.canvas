      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,600&family=JetBrains+Mono:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.css');\n</style>\n\n\n<div class=\"w-full bg-[#09090b] px-16 pt-20 pb-16 relative overflow-hidden\" data-kid=\"1\">\n  <div class=\"absolute inset-0 opacity-30\" style=\"background: radial-gradient(ellipse 60% 50% at 30% 40%, #0b57d0 0%, transparent 70%), radial-gradient(ellipse 40% 60% at 80% 60%, #137333 0%, transparent 70%);\" data-kid=\"2\"></div>\n  <div class=\"relative z-10 max-w-[1200px] mx-auto\" data-kid=\"3\">\n    <div class=\"flex items-center gap-3 mb-6\" data-kid=\"4\">\n      <div class=\"w-10 h-10 rounded-full bg-[#0b57d0] flex items-center justify-center\" data-kid=\"5\">\n        <i class=\"ri-palette-line text-white text-lg\" data-kid=\"6\"></i>\n      </div>\n      <span class=\"text-[#71717a] font-semibold text-xs tracking-[0.15em] uppercase\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"7\">Design System Audit</span>\n    </div>\n    <h1 class=\"text-white text-5xl font-extrabold leading-[1.1] tracking-[-0.03em] mb-5\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"8\">\n      Voice Agent Studio<br data-kid=\"9\">\n      <span class=\"text-[#6ea8fe]\" data-kid=\"10\">Points d'amélioration</span>\n    </h1>\n    <p class=\"text-[#a1a1aa] text-lg max-w-[700px] leading-relaxed\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"11\">\n      Analyse complète du design system actuel avec recommandations concrètes pour renforcer la cohérence, l'accessibilité et la scalabilité.\n    </p>\n  </div>\n</div>\n\n\n<div class=\"w-full bg-[#f8fafc] px-16 py-14\" data-kid=\"12\">\n  <div class=\"max-w-[1200px] mx-auto\" data-kid=\"13\">\n    <div class=\"grid grid-cols-5 gap-5\" data-kid=\"14\">\n      \n      <div class=\"bg-white rounded-2xl border border-[#e5eaf0] p-6 flex flex-col items-center gap-3 shadow-[0_2px_8px_rgba(15,23,42,0.04)]\" data-kid=\"15\">\n        <div class=\"w-16 h-16 rounded-full border-4 border-[#0b57d0] flex items-center justify-center\" data-kid=\"16\">\n          <span class=\"text-[#0b57d0] text-2xl font-extrabold\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"17\">B+</span>\n        </div>\n        <span class=\"text-[#09090b] text-sm font-bold text-center\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"18\">Score Global</span>\n        <span class=\"text-[#71717a] text-xs text-center\" data-kid=\"19\">Bonne base, améliorations clés possibles</span>\n      </div>\n      \n      <div class=\"bg-white rounded-2xl border border-[#ceead6] p-6 flex flex-col items-center gap-3 shadow-[0_2px_8px_rgba(15,23,42,0.04)]\" data-kid=\"20\">\n        <div class=\"w-12 h-12 rounded-xl bg-[#e6f4ea] flex items-center justify-center\" data-kid=\"21\">\n          <i class=\"ri-paint-brush-line text-[#137333] text-xl\" data-kid=\"22\"></i>\n        </div>\n        <span class=\"text-[#09090b] text-sm font-bold text-center\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"23\">Tokens</span>\n        <div class=\"flex items-center gap-1.5\" data-kid=\"24\">\n          <div class=\"w-2 h-2 rounded-full bg-[#137333]\" data-kid=\"25\"></div>\n          <span class=\"text-[#137333] text-xs font-semibold\" data-kid=\"26\">Bien structurés</span>\n        </div>\n      </div>\n      \n      <div class=\"bg-white rounded-2xl border border-[#d2e3fc] p-6 flex flex-col items-center gap-3 shadow-[0_2px_8px_rgba(15,23,42,0.04)]\" data-kid=\"27\">\n        <div class=\"w-12 h-12 rounded-xl bg-[#e8f0fe] flex items-center justify-center\" data-kid=\"28\">\n          <i class=\"ri-font-size-2 text-[#0b57d0] text-xl\" data-kid=\"29\"></i>\n        </div>\n        <span class=\"text-[#09090b] text-sm font-bold text-center\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"30\">Typography</span>\n        <div class=\"flex items-center gap-1.5\" data-kid=\"31\">\n          <div class=\"w-2 h-2 rounded-full bg-[#b06000]\" data-kid=\"32\"></div>\n          <span class=\"text-[#b06000] text-xs font-semibold\" data-kid=\"33\">Scale manquante</span>\n        </div>\n      </div>\n      \n      <div class=\"bg-white rounded-2xl border border-[#feebc8] p-6 flex flex-col items-center gap-3 shadow-[0_2px_8px_rgba(15,23,42,0.04)]\" data-kid=\"34\">\n        <div class=\"w-12 h-12 rounded-xl bg-[#fef7e0] flex items-center justify-center\" data-kid=\"35\">\n          <i class=\"ri-space text-[#b06000] text-xl\" data-kid=\"36\"></i>\n        </div>\n        <span class=\"text-[#09090b] text-sm font-bold text-center\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"37\">Spacing</span>\n        <div class=\"flex items-center gap-1.5\" data-kid=\"38\">\n          <div class=\"w-2 h-2 rounded-full bg-[#c5221f]\" data-kid=\"39\"></div>\n          <span class=\"text-[#c5221f] text-xs font-semibold\" data-kid=\"40\">Non tokenisé</span>\n        </div>\n      </div>\n      \n      <div class=\"bg-white rounded-2xl border border-[#fad2cf] p-6 flex flex-col items-center gap-3 shadow-[0_2px_8px_rgba(15,23,42,0.04)]\" data-kid=\"41\">\n        <div class=\"w-12 h-12 rounded-xl bg-[#fce8e6] flex items-center justify-center\" data-kid=\"42\">\n          <i class=\"ri-eye-line text-[#c5221f] text-xl\" data-kid=\"43\"></i>\n        </div>\n        <span class=\"text-[#09090b] text-sm font-bold text-center\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"44\">Accessibilité</span>\n        <div class=\"flex items-center gap-1.5\" data-kid=\"45\">\n          <div class=\"w-2 h-2 rounded-full bg-[#c5221f]\" data-kid=\"46\"></div>\n          <span class=\"text-[#c5221f] text-xs font-semibold\" data-kid=\"47\">Pas de dark mode</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"w-full bg-white px-16 py-14 border-t border-[#e5eaf0]\" data-kid=\"48\">\n  <div class=\"max-w-[1200px] mx-auto\" data-kid=\"49\">\n    <div class=\"flex items-center gap-3 mb-2\" data-kid=\"50\">\n      <i class=\"ri-thumb-up-fill text-[#137333] text-xl\" data-kid=\"51\"></i>\n      <span class=\"text-[#137333] font-bold text-xs tracking-[0.12em] uppercase\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"52\">Ce qui fonctionne bien</span>\n    </div>\n    <h2 class=\"text-[#09090b] text-3xl font-extrabold tracking-[-0.02em] mb-10\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"53\">Points forts du design system</h2>\n    \n    <div class=\"grid grid-cols-3 gap-6\" data-kid=\"54\">\n      <div class=\"group relative bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0] hover:border-[#ceead6] transition-all duration-200\" data-kid=\"55\">\n        <div class=\"absolute top-0 left-8 right-8 h-[3px] bg-[#137333] rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"56\"></div>\n        <div class=\"flex items-start gap-4 mb-4\" data-kid=\"57\">\n          <div class=\"w-10 h-10 rounded-xl bg-[#e6f4ea] flex items-center justify-center shrink-0\" data-kid=\"58\">\n            <i class=\"ri-css3-fill text-[#137333] text-lg\" data-kid=\"59\"></i>\n          </div>\n          <div data-kid=\"60\">\n            <h3 class=\"text-[#09090b] text-base font-bold mb-1\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"61\">Tokens CSS centralisés</h3>\n            <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"62\">Un seul fichier <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#0b57d0]\" data-kid=\"63\">design-system.css</code> avec des variables sémantiques bien nommées (<code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#0b57d0]\" data-kid=\"64\">--studio-*</code>).</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group relative bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0] hover:border-[#ceead6] transition-all duration-200\" data-kid=\"65\">\n        <div class=\"absolute top-0 left-8 right-8 h-[3px] bg-[#137333] rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"66\"></div>\n        <div class=\"flex items-start gap-4 mb-4\" data-kid=\"67\">\n          <div class=\"w-10 h-10 rounded-xl bg-[#e6f4ea] flex items-center justify-center shrink-0\" data-kid=\"68\">\n            <i class=\"ri-palette-line text-[#137333] text-lg\" data-kid=\"69\"></i>\n          </div>\n          <div data-kid=\"70\">\n            <h3 class=\"text-[#09090b] text-base font-bold mb-1\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"71\">Palette couleur cohérente</h3>\n            <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"72\">Système action/success/warning/danger avec variantes <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#0b57d0]\" data-kid=\"73\">-soft</code> et <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#0b57d0]\" data-kid=\"74\">-border</code> bien pensé.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group relative bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0] hover:border-[#ceead6] transition-all duration-200\" data-kid=\"75\">\n        <div class=\"absolute top-0 left-8 right-8 h-[3px] bg-[#137333] rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"76\"></div>\n        <div class=\"flex items-start gap-4 mb-4\" data-kid=\"77\">\n          <div class=\"w-10 h-10 rounded-xl bg-[#e6f4ea] flex items-center justify-center shrink-0\" data-kid=\"78\">\n            <i class=\"ri-text text-[#137333] text-lg\" data-kid=\"79\"></i>\n          </div>\n          <div data-kid=\"80\">\n            <h3 class=\"text-[#09090b] text-base font-bold mb-1\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"81\">Duo typo solide</h3>\n            <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"82\">Outfit (display) + Plus Jakarta Sans (body) : choix premium avec forte personnalité et lisibilité.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group relative bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0] hover:border-[#ceead6] transition-all duration-200\" data-kid=\"83\">\n        <div class=\"absolute top-0 left-8 right-8 h-[3px] bg-[#137333] rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"84\"></div>\n        <div class=\"flex items-start gap-4 mb-4\" data-kid=\"85\">\n          <div class=\"w-10 h-10 rounded-xl bg-[#e6f4ea] flex items-center justify-center shrink-0\" data-kid=\"86\">\n            <i class=\"ri-input-method-line text-[#137333] text-lg\" data-kid=\"87\"></i>\n          </div>\n          <div data-kid=\"88\">\n            <h3 class=\"text-[#09090b] text-base font-bold mb-1\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"89\">Composants form bien finis</h3>\n            <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"90\">Inputs, selects, textareas avec focus ring, hover states, et disabled cohérents. Touch targets de 44px.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group relative bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0] hover:border-[#ceead6] transition-all duration-200\" data-kid=\"91\">\n        <div class=\"absolute top-0 left-8 right-8 h-[3px] bg-[#137333] rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"92\"></div>\n        <div class=\"flex items-start gap-4 mb-4\" data-kid=\"93\">\n          <div class=\"w-10 h-10 rounded-xl bg-[#e6f4ea] flex items-center justify-center shrink-0\" data-kid=\"94\">\n            <i class=\"ri-layout-line text-[#137333] text-lg\" data-kid=\"95\"></i>\n          </div>\n          <div data-kid=\"96\">\n            <h3 class=\"text-[#09090b] text-base font-bold mb-1\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"97\">Shell layout structuré</h3>\n            <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"98\">StudioShell avec sidebar, topbar et zones de contenu bien découpées. Navigation claire par icônes.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group relative bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0] hover:border-[#ceead6] transition-all duration-200\" data-kid=\"99\">\n        <div class=\"absolute top-0 left-8 right-8 h-[3px] bg-[#137333] rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"100\"></div>\n        <div class=\"flex items-start gap-4 mb-4\" data-kid=\"101\">\n          <div class=\"w-10 h-10 rounded-xl bg-[#e6f4ea] flex items-center justify-center shrink-0\" data-kid=\"102\">\n            <i class=\"ri-button-line text-[#137333] text-lg\" data-kid=\"103\"></i>\n          </div>\n          <div data-kid=\"104\">\n            <h3 class=\"text-[#09090b] text-base font-bold mb-1\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"105\">Boutons M3-inspired</h3>\n            <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"106\">Pills arrondis (9999px) avec variantes primary/ghost/default et micro-animations (translateY).</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"w-full bg-[#f8fafc] px-16 py-14 border-t border-[#e5eaf0]\" data-kid=\"107\">\n  <div class=\"max-w-[1200px] mx-auto\" data-kid=\"108\">\n    <div class=\"flex items-center gap-3 mb-2\" data-kid=\"109\">\n      <i class=\"ri-error-warning-fill text-[#c5221f] text-xl\" data-kid=\"110\"></i>\n      <span class=\"text-[#c5221f] font-bold text-xs tracking-[0.12em] uppercase\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"111\">Problèmes critiques</span>\n    </div>\n    <h2 class=\"text-[#09090b] text-3xl font-extrabold tracking-[-0.02em] mb-10\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"112\">Améliorations prioritaires</h2>\n\n    \n    <div class=\"bg-white rounded-2xl border border-[#fad2cf] p-8 mb-6 relative overflow-hidden\" data-kid=\"113\">\n      <div class=\"absolute left-0 top-0 bottom-0 w-1.5 bg-[#c5221f] rounded-r-full\" data-kid=\"114\"></div>\n      <div class=\"ml-4\" data-kid=\"115\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"116\">\n          <span class=\"bg-[#fce8e6] text-[#c5221f] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"117\">Priorité 1</span>\n          <span class=\"bg-[#fce8e6] text-[#c5221f] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"118\">Dette technique</span>\n        </div>\n        <h3 class=\"text-[#09090b] text-xl font-bold mb-3\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"119\">Finaliser la migration des alias legacy</h3>\n        <p class=\"text-[#3f3f46] text-sm leading-relaxed mb-5\" data-kid=\"120\">Vous avez ~25 alias backward-compatible (<code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#c5221f]\" data-kid=\"121\">--slate-*</code>, <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#c5221f]\" data-kid=\"122\">--google-*</code>, <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#c5221f]\" data-kid=\"123\">--bg-*</code>) qui coexistent avec les tokens <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono text-[#137333]\" data-kid=\"124\">--studio-*</code>. Ça crée de la confusion et double les points de maintenance.</p>\n        <div class=\"bg-[#fce8e6]/40 rounded-xl p-5 border border-[#fad2cf]\" data-kid=\"125\">\n          <p class=\"text-[#09090b] text-sm font-semibold mb-2\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"126\">💡 Action recommandée</p>\n          <ol class=\"text-[#3f3f46] text-sm leading-relaxed list-decimal list-inside space-y-1\" data-kid=\"127\">\n            <li data-kid=\"128\">Grep tous les usages de <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"129\">--slate-</code>, <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"130\">--google-</code>, <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"131\">--bg-</code> dans les CSS</li>\n            <li data-kid=\"132\">Remplacer par les tokens <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"133\">--studio-*</code> correspondants</li>\n            <li data-kid=\"134\">Supprimer tout le bloc d'alias de <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"135\">design-system.css</code></li>\n          </ol>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white rounded-2xl border border-[#fad2cf] p-8 mb-6 relative overflow-hidden\" data-kid=\"136\">\n      <div class=\"absolute left-0 top-0 bottom-0 w-1.5 bg-[#c5221f] rounded-r-full\" data-kid=\"137\"></div>\n      <div class=\"ml-4\" data-kid=\"138\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"139\">\n          <span class=\"bg-[#fce8e6] text-[#c5221f] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"140\">Priorité 1</span>\n          <span class=\"bg-[#fef7e0] text-[#b06000] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"141\">Scalabilité</span>\n        </div>\n        <h3 class=\"text-[#09090b] text-xl font-bold mb-3\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"142\">Pas d'échelle typographique tokenisée</h3>\n        <p class=\"text-[#3f3f46] text-sm leading-relaxed mb-5\" data-kid=\"143\">Les tailles de texte sont définies en valeurs magiques dispersées dans les CSS (11px, 13px, 13.5px, 24px…). Aucun token <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"144\">--studio-text-*</code> pour la typographie.</p>\n        <div class=\"bg-[#f8fafc] rounded-xl p-5 border border-[#e5eaf0]\" data-kid=\"145\">\n          <p class=\"text-[#09090b] text-sm font-semibold mb-3\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"146\">💡 Échelle proposée</p>\n          <div class=\"grid grid-cols-2 gap-x-10 gap-y-2\" data-kid=\"147\">\n            <div class=\"flex items-baseline justify-between\" data-kid=\"148\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"149\">--studio-text-xs</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"150\">11px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"151\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"152\">--studio-text-sm</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"153\">13px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"154\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"155\">--studio-text-base</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"156\">15px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"157\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"158\">--studio-text-lg</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"159\">18px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"160\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"161\">--studio-text-xl</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"162\">22px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"163\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"164\">--studio-text-2xl</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"165\">28px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"166\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"167\">--studio-text-3xl</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"168\">36px</span>\n            </div>\n            <div class=\"flex items-baseline justify-between\" data-kid=\"169\">\n              <code class=\"text-xs font-mono text-[#0b57d0]\" data-kid=\"170\">--studio-text-4xl</code>\n              <span class=\"text-[#71717a] text-xs\" data-kid=\"171\">48px</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white rounded-2xl border border-[#fad2cf] p-8 mb-6 relative overflow-hidden\" data-kid=\"172\">\n      <div class=\"absolute left-0 top-0 bottom-0 w-1.5 bg-[#c5221f] rounded-r-full\" data-kid=\"173\"></div>\n      <div class=\"ml-4\" data-kid=\"174\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"175\">\n          <span class=\"bg-[#fce8e6] text-[#c5221f] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"176\">Priorité 1</span>\n          <span class=\"bg-[#fef7e0] text-[#b06000] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"177\">Cohérence</span>\n        </div>\n        <h3 class=\"text-[#09090b] text-xl font-bold mb-3\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"178\">Aucun token de spacing</h3>\n        <p class=\"text-[#3f3f46] text-sm leading-relaxed mb-5\" data-kid=\"179\">Toutes les valeurs de padding/margin/gap sont en pixels bruts (6px, 8px, 12px, 14px, 16px, 20px, 24px, 28px). Pas de grille de spacing définie = dérive visuelle inévitable.</p>\n        <div class=\"bg-[#f8fafc] rounded-xl p-5 border border-[#e5eaf0]\" data-kid=\"180\">\n          <p class=\"text-[#09090b] text-sm font-semibold mb-3\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"181\">💡 Grille 4px proposée</p>\n          <div class=\"flex flex-wrap gap-3\" data-kid=\"182\">\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"183\">\n              <div class=\"w-4 h-4 bg-[#0b57d0] rounded-[2px]\" style=\"width:4px; height:4px;\" data-kid=\"184\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"185\">--sp-1</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"186\">4px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"187\">\n              <div class=\"w-4 h-4 bg-[#0b57d0] rounded-[2px]\" style=\"width:8px; height:8px;\" data-kid=\"188\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"189\">--sp-2</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"190\">8px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"191\">\n              <div class=\"bg-[#0b57d0] rounded-[2px]\" style=\"width:12px; height:12px;\" data-kid=\"192\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"193\">--sp-3</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"194\">12px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"195\">\n              <div class=\"bg-[#0b57d0] rounded-[3px]\" style=\"width:16px; height:16px;\" data-kid=\"196\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"197\">--sp-4</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"198\">16px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"199\">\n              <div class=\"bg-[#0b57d0] rounded-[3px]\" style=\"width:20px; height:20px;\" data-kid=\"200\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"201\">--sp-5</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"202\">20px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"203\">\n              <div class=\"bg-[#0b57d0] rounded-[3px]\" style=\"width:24px; height:24px;\" data-kid=\"204\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"205\">--sp-6</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"206\">24px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"207\">\n              <div class=\"bg-[#0b57d0] rounded-[4px]\" style=\"width:32px; height:32px;\" data-kid=\"208\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"209\">--sp-8</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"210\">32px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"211\">\n              <div class=\"bg-[#0b57d0] rounded-[4px]\" style=\"width:40px; height:40px;\" data-kid=\"212\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"213\">--sp-10</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"214\">40px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"215\">\n              <div class=\"bg-[#0b57d0] rounded-[5px]\" style=\"width:48px; height:48px;\" data-kid=\"216\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"217\">--sp-12</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"218\">48px</span>\n            </div>\n            <div class=\"flex flex-col items-center gap-1\" data-kid=\"219\">\n              <div class=\"bg-[#0b57d0] rounded-[5px]\" style=\"width:56px; height:56px;\" data-kid=\"220\"></div>\n              <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"221\">--sp-16</code>\n              <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"222\">64px</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white rounded-2xl border border-[#feebc8] p-8 mb-6 relative overflow-hidden\" data-kid=\"223\">\n      <div class=\"absolute left-0 top-0 bottom-0 w-1.5 bg-[#b06000] rounded-r-full\" data-kid=\"224\"></div>\n      <div class=\"ml-4\" data-kid=\"225\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"226\">\n          <span class=\"bg-[#fef7e0] text-[#b06000] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"227\">Priorité 2</span>\n          <span class=\"bg-[#fef7e0] text-[#b06000] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"228\">UX</span>\n        </div>\n        <h3 class=\"text-[#09090b] text-xl font-bold mb-3\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"229\">Pas de dark mode préparé</h3>\n        <p class=\"text-[#3f3f46] text-sm leading-relaxed mb-5\" data-kid=\"230\">Le <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"231\">color-scheme: light</code> est hardcodé. Pour un outil studio utilisé en longue session, le dark mode est quasi indispensable. Votre architecture tokens le permet facilement.</p>\n        <div class=\"bg-[#09090b] rounded-xl p-5 border border-[#27272a] flex items-center gap-6\" data-kid=\"232\">\n          <div class=\"flex-1\" data-kid=\"233\">\n            <p class=\"text-white text-sm font-semibold mb-2\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"234\">Préparer avec <code class=\"text-[#6ea8fe] text-xs\" data-kid=\"235\">@media (prefers-color-scheme: dark)</code></p>\n            <p class=\"text-[#a1a1aa] text-xs leading-relaxed\" data-kid=\"236\">Surcharger les variables <code class=\"text-[#6ea8fe]\" data-kid=\"237\">--studio-*</code> dans un bloc dark. Pas besoin de toucher aux composants.</p>\n          </div>\n          <div class=\"flex gap-2\" data-kid=\"238\">\n            <div class=\"w-8 h-8 rounded-lg bg-[#1a1a2e]\" title=\"--studio-bg\" data-kid=\"239\"></div>\n            <div class=\"w-8 h-8 rounded-lg bg-[#16213e]\" title=\"--studio-surface\" data-kid=\"240\"></div>\n            <div class=\"w-8 h-8 rounded-lg bg-[#0f3460]\" title=\"--studio-action\" data-kid=\"241\"></div>\n            <div class=\"w-8 h-8 rounded-lg bg-[#e2e8f0]\" title=\"--studio-text\" data-kid=\"242\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white rounded-2xl border border-[#feebc8] p-8 mb-6 relative overflow-hidden\" data-kid=\"243\">\n      <div class=\"absolute left-0 top-0 bottom-0 w-1.5 bg-[#b06000] rounded-r-full\" data-kid=\"244\"></div>\n      <div class=\"ml-4\" data-kid=\"245\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"246\">\n          <span class=\"bg-[#fef7e0] text-[#b06000] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"247\">Priorité 2</span>\n          <span class=\"bg-[#e8f0fe] text-[#0b57d0] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"248\">Cohérence</span>\n        </div>\n        <h3 class=\"text-[#09090b] text-xl font-bold mb-3\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"249\">Incohérence des border-radius</h3>\n        <p class=\"text-[#3f3f46] text-sm leading-relaxed mb-5\" data-kid=\"250\">Vous avez 2 tokens (8px, 16px) mais les composants utilisent aussi 10px (inputs), 9999px (boutons), et des valeurs custom. Le mélange crée un langage visuel flou.</p>\n        <div class=\"grid grid-cols-4 gap-4\" data-kid=\"251\">\n          <div class=\"flex flex-col items-center gap-2\" data-kid=\"252\">\n            <div class=\"w-16 h-12 bg-[#e8f0fe] border-2 border-[#0b57d0] rounded-[4px]\" data-kid=\"253\"></div>\n            <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"254\">--radius-xs: 4px</code>\n            <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"255\">Tags, badges</span>\n          </div>\n          <div class=\"flex flex-col items-center gap-2\" data-kid=\"256\">\n            <div class=\"w-16 h-12 bg-[#e8f0fe] border-2 border-[#0b57d0] rounded-[8px]\" data-kid=\"257\"></div>\n            <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"258\">--radius-sm: 8px</code>\n            <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"259\">Inputs, chips</span>\n          </div>\n          <div class=\"flex flex-col items-center gap-2\" data-kid=\"260\">\n            <div class=\"w-16 h-12 bg-[#e8f0fe] border-2 border-[#0b57d0] rounded-[16px]\" data-kid=\"261\"></div>\n            <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"262\">--radius-md: 16px</code>\n            <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"263\">Cards, panels</span>\n          </div>\n          <div class=\"flex flex-col items-center gap-2\" data-kid=\"264\">\n            <div class=\"w-16 h-12 bg-[#e8f0fe] border-2 border-[#0b57d0] rounded-full\" data-kid=\"265\"></div>\n            <code class=\"text-[10px] font-mono text-[#71717a]\" data-kid=\"266\">--radius-full: 9999px</code>\n            <span class=\"text-[10px] text-[#a1a1aa]\" data-kid=\"267\">Boutons, pills</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white rounded-2xl border border-[#d2e3fc] p-8 mb-6 relative overflow-hidden\" data-kid=\"268\">\n      <div class=\"absolute left-0 top-0 bottom-0 w-1.5 bg-[#0b57d0] rounded-r-full\" data-kid=\"269\"></div>\n      <div class=\"ml-4\" data-kid=\"270\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"271\">\n          <span class=\"bg-[#e8f0fe] text-[#0b57d0] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"272\">Priorité 3</span>\n          <span class=\"bg-[#e8f0fe] text-[#0b57d0] text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"273\">Token hygiene</span>\n        </div>\n        <h3 class=\"text-[#09090b] text-xl font-bold mb-3\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"274\">Shadow & radius aliases redondants</h3>\n        <p class=\"text-[#3f3f46] text-sm leading-relaxed mb-4\" data-kid=\"275\">\n          <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"276\">--shadow-lg</code> pointe vers <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"277\">--studio-shadow-md</code> (identique à <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"278\">--shadow-md</code>). \n          <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"279\">--radius-md</code> et <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"280\">--radius-lg</code> sont identiques.\n          Ajouter un vrai <code class=\"bg-[#f1f5f9] px-1.5 py-0.5 rounded text-xs font-mono\" data-kid=\"281\">--studio-shadow-lg</code> pour les modals/dropdowns.\n        </p>\n      </div>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"w-full bg-white px-16 py-14 border-t border-[#e5eaf0]\" data-kid=\"282\">\n  <div class=\"max-w-[1200px] mx-auto\" data-kid=\"283\">\n    <div class=\"flex items-center gap-3 mb-2\" data-kid=\"284\">\n      <i class=\"ri-lightbulb-fill text-[#b06000] text-xl\" data-kid=\"285\"></i>\n      <span class=\"text-[#b06000] font-bold text-xs tracking-[0.12em] uppercase\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"286\">Observations UX/UI</span>\n    </div>\n    <h2 class=\"text-[#09090b] text-3xl font-extrabold tracking-[-0.02em] mb-10\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"287\">Ce que j'ai observé dans les écrans</h2>\n\n    <div class=\"grid grid-cols-2 gap-6\" data-kid=\"288\">\n\n      \n      <div class=\"bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0]\" data-kid=\"289\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"290\">\n          <div class=\"w-8 h-8 rounded-lg bg-[#fef7e0] flex items-center justify-center\" data-kid=\"291\">\n            <span class=\"text-base\" data-kid=\"292\">📐</span>\n          </div>\n          <h3 class=\"text-[#09090b] text-sm font-bold\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"293\">Densité d'information variable</h3>\n        </div>\n        <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"294\">Le Builder est très aéré tandis que l'écran Environment est très dense. Définir un système de sections avec padding constant (ex: 24px interne, 32px entre sections) uniformiserait le rythme.</p>\n      </div>\n\n      \n      <div class=\"bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0]\" data-kid=\"295\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"296\">\n          <div class=\"w-8 h-8 rounded-lg bg-[#fef7e0] flex items-center justify-center\" data-kid=\"297\">\n            <span class=\"text-base\" data-kid=\"298\">🃏</span>\n          </div>\n          <h3 class=\"text-[#09090b] text-sm font-bold\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"299\">Cards sans hiérarchie visuelle claire</h3>\n        </div>\n        <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"300\">Les cards du Command Center (Realtime/Builder/Operations) et la sidebar détails utilisent le même style. Créer des variantes <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"301\">card-elevated</code> vs <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"302\">card-flat</code> clarifierait la hiérarchie.</p>\n      </div>\n\n      \n      <div class=\"bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0]\" data-kid=\"303\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"304\">\n          <div class=\"w-8 h-8 rounded-lg bg-[#fef7e0] flex items-center justify-center\" data-kid=\"305\">\n            <span class=\"text-base\" data-kid=\"306\">🏷️</span>\n          </div>\n          <h3 class=\"text-[#09090b] text-sm font-bold\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"307\">Status badges incohérents</h3>\n        </div>\n        <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"308\">Les badges \"COMPILED\", \"READY FOR RTC\" ont des styles différents selon les écrans (couleurs de fond, taille, border). Créer un composant Badge unifié avec variantes <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"309\">success</code>, <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"310\">info</code>, <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"311\">neutral</code>.</p>\n      </div>\n\n      \n      <div class=\"bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0]\" data-kid=\"312\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"313\">\n          <div class=\"w-8 h-8 rounded-lg bg-[#fef7e0] flex items-center justify-center\" data-kid=\"314\">\n            <span class=\"text-base\" data-kid=\"315\">📱</span>\n          </div>\n          <h3 class=\"text-[#09090b] text-sm font-bold\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"316\">Sidebar manque d'affordance</h3>\n        </div>\n        <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"317\">La sidebar icon-only est minimale mais les labels ne sont visibles qu'au hover. Ajouter des tooltips ou un mode collapsed/expanded avec un toggle améliorerait l'onboarding.</p>\n      </div>\n\n      \n      <div class=\"bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0]\" data-kid=\"318\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"319\">\n          <div class=\"w-8 h-8 rounded-lg bg-[#fef7e0] flex items-center justify-center\" data-kid=\"320\">\n            <span class=\"text-base\" data-kid=\"321\">🔤</span>\n          </div>\n          <h3 class=\"text-[#09090b] text-sm font-bold\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"322\">h2 trop petit et ambigu</h3>\n        </div>\n        <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"323\">Le <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"324\">h2</code> global est stylé en 13px uppercase (eyebrow). C'est sémantiquement un label, pas un heading. Libérer le h2 pour de vrais titres de section et utiliser une classe <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"325\">.eyebrow</code> dédiée.</p>\n      </div>\n\n      \n      <div class=\"bg-[#f8fafc] rounded-2xl p-7 border border-[#e5eaf0]\" data-kid=\"326\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"327\">\n          <div class=\"w-8 h-8 rounded-lg bg-[#fef7e0] flex items-center justify-center\" data-kid=\"328\">\n            <span class=\"text-base\" data-kid=\"329\">⚡</span>\n          </div>\n          <h3 class=\"text-[#09090b] text-sm font-bold\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"330\">Animations basiques</h3>\n        </div>\n        <p class=\"text-[#71717a] text-sm leading-relaxed\" data-kid=\"331\">Une seule animation <code class=\"bg-white px-1 rounded text-xs font-mono\" data-kid=\"332\">fadeIn</code> globale. Pour un outil \"studio\", ajouter des transitions de page (slide-in), des skeleton loaders, et des micro-interactions sur les cards donnerait un feeling pro.</p>\n      </div>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"w-full bg-[#09090b] px-16 py-16 border-t border-[#27272a]\" data-kid=\"333\">\n  <div class=\"max-w-[1200px] mx-auto\" data-kid=\"334\">\n    <div class=\"flex items-center gap-3 mb-2\" data-kid=\"335\">\n      <i class=\"ri-roadmap-fill text-[#6ea8fe] text-xl\" data-kid=\"336\"></i>\n      <span class=\"text-[#6ea8fe] font-bold text-xs tracking-[0.12em] uppercase\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"337\">Roadmap suggérée</span>\n    </div>\n    <h2 class=\"text-white text-3xl font-extrabold tracking-[-0.02em] mb-12\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"338\">Plan d'action en 3 phases</h2>\n\n    <div class=\"grid grid-cols-3 gap-8\" data-kid=\"339\">\n      \n      <div class=\"relative\" data-kid=\"340\">\n        <div class=\"absolute -top-3 left-6 bg-[#c5221f] text-white text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"341\">Sprint 1</div>\n        <div class=\"bg-[#18181b] rounded-2xl border border-[#27272a] p-7 pt-8\" data-kid=\"342\">\n          <h3 class=\"text-white text-lg font-bold mb-1\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"343\">🧹 Clean & Consolidate</h3>\n          <p class=\"text-[#71717a] text-xs mb-5\" data-kid=\"344\">Effort: ~2-3 jours</p>\n          <ul class=\"space-y-3\" data-kid=\"345\">\n            <li class=\"flex items-start gap-2.5\" data-kid=\"346\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"347\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"348\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"349\">Supprimer tous les alias legacy</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"350\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"351\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"352\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"353\">Ajouter tokens typography scale</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"354\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"355\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"356\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"357\">Ajouter tokens spacing (grille 4px)</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"358\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"359\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"360\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"361\">Uniformiser les border-radius</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"362\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"363\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"364\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"365\">Libérer h2 sémantique</span>\n            </li>\n          </ul>\n        </div>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"366\">\n        <div class=\"absolute -top-3 left-6 bg-[#b06000] text-white text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"367\">Sprint 2</div>\n        <div class=\"bg-[#18181b] rounded-2xl border border-[#27272a] p-7 pt-8\" data-kid=\"368\">\n          <h3 class=\"text-white text-lg font-bold mb-1\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"369\">🧩 Component Library</h3>\n          <p class=\"text-[#71717a] text-xs mb-5\" data-kid=\"370\">Effort: ~3-4 jours</p>\n          <ul class=\"space-y-3\" data-kid=\"371\">\n            <li class=\"flex items-start gap-2.5\" data-kid=\"372\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"373\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"374\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"375\">Badge unifié (success/info/warning/danger)</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"376\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"377\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"378\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"379\">Card variantes (elevated / flat / outlined)</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"380\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"381\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"382\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"383\">Skeleton loaders</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"384\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"385\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"386\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"387\">Tooltip component</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"388\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"389\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"390\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"391\">Page transition animations</span>\n            </li>\n          </ul>\n        </div>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"392\">\n        <div class=\"absolute -top-3 left-6 bg-[#0b57d0] text-white text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded-full\" data-kid=\"393\">Sprint 3</div>\n        <div class=\"bg-[#18181b] rounded-2xl border border-[#27272a] p-7 pt-8\" data-kid=\"394\">\n          <h3 class=\"text-white text-lg font-bold mb-1\" style=\"font-family: 'Outfit', sans-serif;\" data-kid=\"395\">🌗 Dark Mode & Polish</h3>\n          <p class=\"text-[#71717a] text-xs mb-5\" data-kid=\"396\">Effort: ~2-3 jours</p>\n          <ul class=\"space-y-3\" data-kid=\"397\">\n            <li class=\"flex items-start gap-2.5\" data-kid=\"398\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"399\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"400\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"401\">Dark mode token overrides</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"402\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"403\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"404\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"405\">Theme toggle in StudioShell</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"406\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"407\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"408\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"409\">Focus visible ring cohérent partout</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"410\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"411\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"412\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"413\">Contrast ratio audit (WCAG AA)</span>\n            </li>\n            <li class=\"flex items-start gap-2.5\" data-kid=\"414\">\n              <div class=\"w-5 h-5 rounded-md bg-[#27272a] flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"415\"><i class=\"ri-checkbox-blank-line text-[#71717a] text-xs\" data-kid=\"416\"></i></div>\n              <span class=\"text-[#a1a1aa] text-sm\" data-kid=\"417\">Sidebar expand/collapse mode</span>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-12 pt-8 border-t border-[#27272a] flex items-center justify-between\" data-kid=\"418\">\n      <p class=\"text-[#71717a] text-sm\" style=\"font-family: 'Plus Jakarta Sans', sans-serif;\" data-kid=\"419\">\n        Total estimé : <span class=\"text-white font-semibold\" data-kid=\"420\">~7-10 jours</span> pour un design system production-ready.\n      </p>\n      <div class=\"flex items-center gap-2 text-[#6ea8fe] text-sm font-semibold\" data-kid=\"421\">\n        <i class=\"ri-arrow-right-line\" data-kid=\"422\"></i>\n        <span data-kid=\"423\">Prêt à implémenter ? Passe en mode Code.</span>\n      </div>\n    </div>\n  </div>\n</div>\n",

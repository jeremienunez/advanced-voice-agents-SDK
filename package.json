{
  "name": "@voiceagentsdk/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agnostic SDK for building provider-pluggable conversational voice agents.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "TODO.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./server/adapters/fastify": {
      "types": "./dist/server/adapters/fastify/index.d.ts",
      "import": "./dist/server/adapters/fastify/index.js"
    },
    "./server/providers": {
      "types": "./dist/server/providers/index.d.ts",
      "import": "./dist/server/providers/index.js"
    },
    "./server/media": {
      "types": "./dist/server/media/index.d.ts",
      "import": "./dist/server/media/index.js"
    },
    "./server/browser": {
      "types": "./dist/server/browser/index.d.ts",
      "import": "./dist/server/browser/index.js"
    },
    "./client/browser": {
      "types": "./dist/client/browser/index.d.ts",
      "import": "./dist/client/browser/index.js"
    }
  },
  "scripts": {
    "prepack": "pnpm build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:sdk": "tsc --noEmit -p tsconfig.json",
    "typecheck:examples": "echo \"No standalone examples to typecheck\"",
    "typecheck:starters": "pnpm --filter @voiceagentsdk/starter-voip-rtc typecheck",
    "dev:voip-rtc": "pnpm --filter @voiceagentsdk/starter-voip-rtc dev",
    "harness:route-wines": "pnpm --filter @voiceagentsdk/starter-voip-rtc harness:route-wines",
    "infra:plan": "pnpm --filter @voiceagentsdk/starter-voip-rtc infra:plan",
    "infra:apply": "pnpm --filter @voiceagentsdk/starter-voip-rtc infra:apply",
    "infra:status": "pnpm --filter @voiceagentsdk/starter-voip-rtc infra:status",
    "infra:destroy": "pnpm --filter @voiceagentsdk/starter-voip-rtc infra:destroy",
    "test:db": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:db",
    "test:database-provisioning": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:database-provisioning",
    "test:db-adapter-registry:bdd": "pnpm build && pnpm --filter @voiceagentsdk/starter-voip-rtc test:db-adapter-registry:bdd",
    "test:adapter-boundaries:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:adapter-boundaries:bdd",
    "test:debug-audio:bdd": "bun run scripts/test-debug-audio-dump-bdd.ts",
    "test:secret-hygiene:bdd": "bun run scripts/test-secret-hygiene-bdd.ts",
    "test:store-adapter-contracts:bdd": "pnpm build && pnpm --filter @voiceagentsdk/starter-voip-rtc test:store-adapter-contracts:bdd",
    "test:builder-draft-ownership:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:builder-draft-ownership:bdd",
    "test:document-ingestion:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:document-ingestion:bdd",
    "test:event-sink-logger-port:bdd": "pnpm build && pnpm --filter @voiceagentsdk/starter-voip-rtc test:event-sink-logger-port:bdd",
    "test:fastify-voice-adapter:bdd": "pnpm build && pnpm exec tsc --noEmit --target ES2023 --module NodeNext --moduleResolution NodeNext --lib ES2023,DOM --strict --skipLibCheck scripts/test-fastify-voice-adapter-bdd.ts && bun run scripts/test-fastify-voice-adapter-bdd.ts",
    "test:infra-evolution-approval:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:infra-evolution-approval:bdd",
    "test:infra-plan": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:infra-plan",
    "test:infra-runner:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:infra-runner:bdd",
    "test:llm-harness": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:llm-harness",
    "test:log-redaction:bdd": "bun run scripts/test-log-redaction-bdd.ts",
    "test:media-bridge-factory:bdd": "pnpm build && pnpm --filter @voiceagentsdk/starter-voip-rtc test:media-bridge-factory:bdd",
    "test:memory-store-port:bdd": "pnpm build && pnpm --filter @voiceagentsdk/starter-voip-rtc test:memory-store-port:bdd",
    "test:prompt-policy:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:prompt-policy:bdd",
    "test:prompt-compiler-port:bdd": "pnpm build && pnpm --filter @voiceagentsdk/starter-voip-rtc test:prompt-compiler-port:bdd",
    "test:provider-factory:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:provider-factory:bdd",
    "test:public-boundaries:bdd": "pnpm build && pnpm exec tsc --noEmit --target ES2023 --module NodeNext --moduleResolution NodeNext --lib ES2023,DOM --strict --skipLibCheck scripts/test-public-boundaries-bdd.ts && bun run scripts/test-public-boundaries-bdd.ts",
    "test:agentrx-diagnostics:bdd": "pnpm build && pnpm exec tsc --noEmit --target ES2023 --module NodeNext --moduleResolution NodeNext --lib ES2023,DOM --strict --skipLibCheck scripts/test-agentrx-diagnostics-bdd.ts && bun run scripts/test-agentrx-diagnostics-bdd.ts",
    "test:runtime-tool-authorization:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:runtime-tool-authorization:bdd",
    "test:tool-contracts:bdd": "tsc --noEmit --target ES2023 --module NodeNext --moduleResolution NodeNext --lib ES2023,DOM --strict --skipLibCheck scripts/type-tests/tool-contracts.ts && pnpm --filter @voiceagentsdk/starter-voip-rtc test:tool-contracts:bdd",
    "test:tool-registry-adapter:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:tool-registry-adapter:bdd",
    "test:runtime-db-credentials:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:runtime-db-credentials:bdd",
    "test:secret-resolver:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:secret-resolver:bdd",
    "test:tenant-resolver:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:tenant-resolver:bdd",
    "test:temporal-worker:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:temporal-worker:bdd",
    "test:redis-memory:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:redis-memory:bdd",
    "test:graph-memory-adapters:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:graph-memory-adapters:bdd",
    "test:learning": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:learning",
    "test:learning:bdd": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:learning:bdd",
    "test:solid-seams": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:solid-seams",
    "test:knowledge-tool": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:knowledge-tool",
    "test:runtime-tool-call": "bun run scripts/test-runtime-tool-call.ts",
    "test:rtc-e2e": "pnpm --filter @voiceagentsdk/starter-voip-rtc test:rtc-e2e",
    "audit:sdk-boundary": "node scripts/audit-sdk-boundary.mjs",
    "audit:imports": "node scripts/audit-core-imports.mjs",
    "audit:tool-contracts": "node scripts/audit-tool-contracts.mjs",
    "audit:architecture": "depcruise --config .dependency-cruiser.cjs --output-type err src starters/voip-rtc/src starters/voip-rtc/server starters/voip-rtc/scripts scripts examples",
    "audit:responsibility": "node scripts/audit-responsibility.mjs",
    "audit:secrets": "bun run scripts/audit-secret-hygiene.ts",
    "audit:local-secrets": "AUDIT_LOCAL_ENV_SECRETS=1 bun run scripts/audit-secret-hygiene.ts",
    "audit:loc": "bun scripts/audit-loc.mjs",
    "audit:solid": "pnpm audit:architecture && pnpm audit:responsibility && pnpm audit:loc && pnpm audit:secrets && pnpm audit:sdk-boundary && pnpm audit:imports && pnpm audit:tool-contracts && pnpm typecheck:sdk && pnpm typecheck:starters && pnpm test:solid-seams && pnpm test:llm-harness && pnpm test:infra-runner:bdd && pnpm test:infra-evolution-approval:bdd && pnpm test:runtime-db-credentials:bdd && pnpm test:secret-resolver:bdd && pnpm test:tenant-resolver:bdd && pnpm test:adapter-boundaries:bdd && pnpm test:temporal-worker:bdd && pnpm test:redis-memory:bdd && pnpm test:graph-memory-adapters:bdd && pnpm test:tool-contracts:bdd && pnpm test:tool-registry-adapter:bdd && pnpm test:secret-hygiene:bdd && pnpm test:log-redaction:bdd && pnpm test:debug-audio:bdd && pnpm test:prompt-policy:bdd && pnpm test:prompt-compiler-port:bdd && pnpm test:event-sink-logger-port:bdd && pnpm test:fastify-voice-adapter:bdd && pnpm test:memory-store-port:bdd && pnpm test:provider-factory:bdd && pnpm test:public-boundaries:bdd && pnpm test:agentrx-diagnostics:bdd && pnpm test:media-bridge-factory:bdd && pnpm test:db-adapter-registry:bdd && pnpm test:store-adapter-contracts:bdd && pnpm test:runtime-tool-authorization:bdd && pnpm test:builder-draft-ownership:bdd && pnpm test:document-ingestion:bdd && pnpm test:database-provisioning && pnpm test:rtc-e2e",
    "pack:dry-run": "pnpm pack --dry-run --json"
  },
  "dependencies": {
    "@shiguredo/rnnoise-wasm": "^2025.1.5",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "dependency-cruiser": "^17.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14"
  }
}

{
  "name": "@voiceagentsdk/starter-voip-rtc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:sdk": "pnpm --dir ../.. build",
    "dev": "bun run scripts/dev.ts",
    "dev:server": "pnpm build:sdk && bun run scripts/dev-server.ts",
    "dev:client": "vite --host 0.0.0.0",
    "db:start": "bun run scripts/dev-db.ts start",
    "db:stop": "bun run scripts/dev-db.ts stop",
    "db:status": "bun run scripts/dev-db.ts status",
    "harness:route-wines": "bun run scripts/route-wines-harness.ts",
    "infra:plan": "bun run scripts/infra-apply.ts plan",
    "infra:apply": "bun run scripts/infra-apply.ts apply",
    "infra:status": "bun run scripts/infra-apply.ts status",
    "infra:destroy": "bun run scripts/infra-apply.ts destroy",
    "test:db": "bun run scripts/test-db.ts",
    "test:database-provisioning": "bun run scripts/test-database-provisioning.ts",
    "test:adapter-boundaries:bdd": "bun run scripts/test-adapter-boundaries-bdd.ts",
    "test:builder-draft-ownership:bdd": "bun run scripts/test-builder-draft-ownership-bdd.ts",
    "test:document-ingestion:bdd": "bun run scripts/test-document-ingestion-bdd.ts && bun run scripts/test-document-ingestion-quota-bdd.ts",
    "test:infra-evolution-approval:bdd": "bun run scripts/test-infra-evolution-approval-bdd.ts",
    "test:infra-plan": "bun run scripts/test-infra-plan.ts",
    "test:infra-runner:bdd": "bun run scripts/test-infra-runner-bdd.ts",
    "test:llm-harness": "bun run scripts/test-llm-harness.ts",
    "test:prompt-policy:bdd": "bun run scripts/test-prompt-policy-bdd.ts",
    "test:runtime-tool-authorization:bdd": "bun run scripts/test-runtime-tool-authorization-bdd.ts",
    "test:tool-contracts:bdd": "bun run scripts/test-tool-contracts-bdd.ts",
    "test:tool-registry-adapter:bdd": "bun run scripts/test-tool-registry-adapter-bdd.ts",
    "test:runtime-db-credentials:bdd": "bun run scripts/test-runtime-db-credentials-bdd.ts",
    "test:temporal-worker:bdd": "bun run scripts/test-temporal-worker-bdd.ts",
    "test:redis-memory:bdd": "bun run scripts/test-redis-memory-bdd.ts",
    "test:graph-memory-adapters:bdd": "bun run scripts/test-graph-memory-adapters-bdd.ts",
    "test:learning": "bun run scripts/test-learning.ts",
    "test:learning:bdd": "bun run scripts/test-learning-bdd.ts",
    "test:solid-seams": "bun run scripts/test-solid-seams.ts",
    "test:knowledge-tool": "bun run scripts/test-knowledge-tool.ts",
    "test:rtc-e2e": "pnpm build:sdk && bun run scripts/test-rtc-e2e.ts",
    "typecheck": "pnpm build:sdk && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@temporalio/client": "^1.17.2",
    "@voiceagentsdk/core": "workspace:*",
    "neo4j-driver": "^6.0.1",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "redis": "^5.12.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.14"
  }
}

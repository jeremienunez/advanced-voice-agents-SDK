DEFAULT_REALTIME_PROVIDER=gemini
GEMINI_API_KEY=...
GEMINI_REALTIME_MODEL=gemini-3.1-flash-live-preview
GEMINI_REALTIME_VOICE=Puck
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_VOICE=marin
# OpenAI audio dumps are disabled unless this is exactly "local".
VOICE_DEBUG_AUDIO=
VOICE_DEBUG_AUDIO_DIR=/tmp/voice-debug
VOICE_SERVER_PORT=8787
VOICE_SERVER_HOST=127.0.0.1
VOICE_PUBLIC_HOST=127.0.0.1
VOICE_ALLOWED_ORIGINS=http://localhost:5177,http://127.0.0.1:5177
# local keeps starter-only DX fallbacks enabled; production refuses them.
VOICE_STARTER_MODE=local
# Required if NODE_ENV=production or VOICE_SERVER_HOST is not loopback.
VOICE_DEV_AUTH_TOKEN=
VITE_DEV_HOST=127.0.0.1
VITE_VOICE_CONFIG_URL=http://127.0.0.1:8787/config
VITE_VOICE_WS_URL=ws://127.0.0.1:8787/voice/ws?tenantId=local&userId=demo
VITE_VOICE_DEV_AUTH_TOKEN=
BUILDER_INFRA_APPLY_DRIVER=dev-local
BUILDER_INFRA_TOFU_MODULE_DIR=
BUILDER_INFRA_COMPUTE_TARGET=local
BUILDER_INFRA_K3S_PORT=16443
# Runtime DB refs use AGENT_DB_RUNTIME_URL_<SCHEMA_TOKEN>.
AGENT_DB_RUNTIME_URL_AGENT_DRAFT_ONBOARDING=
BUILDER_DOCUMENT_PARSE_TIMEOUT_MS=5000
BUILDER_DOCUMENT_INGESTION_QUOTA_PER_IP=20
BUILDER_DOCUMENT_INGESTION_QUOTA_WINDOW_MS=60000
AGENT_LEARNING_ENABLED=true
AGENT_LEARNING_PROFILE=auto_apply_prompt_safe
AGENT_LEARNING_WORKFLOW_DRIVER=local
AGENT_LEARNING_MEMORY_DRIVER=local
AGENT_LEARNING_MEMORY_NAMESPACE=agent-learning
AGENT_LEARNING_MEMORY_TTL_SECONDS=2592000
AGENT_LEARNING_GRAPH_DRIVER=local
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=
MEMGRAPH_URI=
GRAPH_DATABASE_URL=
GRAPH_DATABASE_USERNAME=
GRAPH_DATABASE_PASSWORD=
NEO4J_USERNAME=
NEO4J_PASSWORD=
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=agent-learning
TEMPORAL_WORKFLOW_TYPE=learnFromSession
